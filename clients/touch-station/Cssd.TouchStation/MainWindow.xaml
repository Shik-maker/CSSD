<Window x:Class="Cssd.TouchStation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSSD消毒供应中心追溯系统"
        Height="960"
        Width="1280"
        MinHeight="760"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="#F5F8FC">
    <Window.Resources>
        <!-- 大按钮样式：用于触摸屏底部操作区，保证手指点击面积足够大。 -->
        <Style x:Key="TouchButton" TargetType="Button">
            <Setter Property="Height" Value="78"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 信息卡样式：统一左侧器械包信息与右侧单据信息的视觉。 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D8E4F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 登录页：对应设计图“触摸端登陆界面”，登录成功后切换到工作台。 -->
        <Grid x:Name="LoginPanel">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#005E62" Offset="0"/>
                    <GradientStop Color="#008D85" Offset=".54"/>
                    <GradientStop Color="#043C54" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*"/>
                <ColumnDefinition Width="520"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="42,36,36,36">
                <StackPanel Orientation="Horizontal">
                    <Border Width="54" Height="54" CornerRadius="14" Background="#1ED6C2">
                        <TextBlock Text="＋" Foreground="White" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0">
                        <TextBlock Text="CSSD 消毒供应中心追溯系统" Foreground="White" FontSize="25" FontWeight="Bold"/>
                        <TextBlock Text="Central Sterile Supply Department Tracking System" Foreground="#CDEBEA" FontSize="14"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="CSSD 消毒供应中心追溯系统" Foreground="White" FontSize="42" FontWeight="Bold" Margin="0,120,0,16"/>
                <TextBlock Text="复用无菌器械全生命周期追溯管理" Foreground="#E6FFFB" FontSize="24"/>

                <StackPanel Orientation="Horizontal" Margin="0,70,0,0">
                    <Border Width="76" Height="76" CornerRadius="38" Margin="0,0,14,0" Background="#70D64A"><TextBlock Text="回收" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <Border Width="76" Height="76" CornerRadius="38" Margin="0,0,14,0" Background="#12C7C0"><TextBlock Text="清洗" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <Border Width="76" Height="76" CornerRadius="38" Margin="0,0,14,0" Background="#1E9BFF"><TextBlock Text="配包" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <Border Width="76" Height="76" CornerRadius="38" Margin="0,0,14,0" Background="#5D8CFF"><TextBlock Text="打包" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <Border Width="76" Height="76" CornerRadius="38" Margin="0,0,14,0" Background="#8065F2"><TextBlock Text="灭菌" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <Border Width="76" Height="76" CornerRadius="38" Margin="0,0,14,0" Background="#0DB8A6"><TextBlock Text="发放" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <Border Width="76" Height="76" CornerRadius="38" Background="#70D64A"><TextBlock Text="回收" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                </StackPanel>

                <UniformGrid Columns="5" Margin="0,180,0,0">
                    <TextBlock Text="全流程追溯" Foreground="White" FontSize="16"/>
                    <TextBlock Text="精益化管理" Foreground="White" FontSize="16"/>
                    <TextBlock Text="质量安全管控" Foreground="White" FontSize="16"/>
                    <TextBlock Text="数据统计分析" Foreground="White" FontSize="16"/>
                    <TextBlock Text="视频过程留痕" Foreground="White" FontSize="16"/>
                </UniformGrid>
            </StackPanel>

            <Border Grid.Column="1" Width="430" Padding="36" CornerRadius="16" Background="#F8FCFF" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="用户登录" FontSize="30" FontWeight="Bold" Foreground="#123156" HorizontalAlignment="Center"/>
                    <TextBlock Text="请扫描工牌或输入用户名登录系统" FontSize="16" Foreground="#708198" Margin="0,12,0,24" HorizontalAlignment="Center"/>
                    <Border Width="190" Height="190" CornerRadius="95" BorderBrush="#9DEBE4" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock Text="扫码" Foreground="#10B7A7" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="用户名 / 工号" Foreground="#52637A" FontSize="15"/>
                    <TextBox x:Name="LoginWorkNoInput" Text="O001" Height="54" FontSize="20" Margin="0,8,0,18" Padding="14,0"/>
                    <Button x:Name="LoginButton" Content="登录" Height="56" Background="#08AD9D" Foreground="White" FontSize="22" FontWeight="Bold" BorderThickness="0" Click="LoginButton_Click"/>
                    <TextBlock x:Name="LoginMessageText" Text="当前终端：回收工位01" Foreground="#52637A" FontSize="14" Margin="0,22,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 工作台：对应设计图“回收触摸台界面”，其他工位通过配置切换文案与接口。 -->
        <Grid x:Name="WorkPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="96"/>
            </Grid.RowDefinitions>

            <Border Background="#073D94">
                <Grid Margin="22,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StationTitleText" Text="CSSD 复用无菌器械闭环追溯系统 - 回收区操作台" Foreground="White" FontSize="25" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="UserNameText" Text="当前用户  张三" Foreground="White" FontSize="16" Margin="0,0,24,0"/>
                        <TextBlock x:Name="DeptText" Text="所属科室  心外科一区" Foreground="White" FontSize="16" Margin="0,0,24,0"/>
                        <TextBlock x:Name="CurrentTimeText" Text="10:30:45" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,24,0"/>
                        <TextBlock x:Name="NetworkText" Text="网络正常" Foreground="#77F0B4" FontSize="16" Margin="0,0,18,0"/>
                        <TextBlock x:Name="WorkMessageText" Text="等待操作" Foreground="#CDEBEA" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <UniformGrid Columns="2" Margin="0,0,0,14">
                        <Button Content="科室回收" Height="54" Background="#176BFF" Foreground="White" FontSize="20" BorderThickness="0"/>
                        <Button Content="PDA清点" Height="54" Background="White" Foreground="#162033" FontSize="20" BorderBrush="#AFC7EA"/>
                    </UniformGrid>
                    <TextBlock Text="科室" Foreground="#123156" FontWeight="Bold" FontSize="16"/>
                    <TextBox x:Name="SecondInput" Text="BASK-01" Height="48" FontSize="18" Margin="0,8,0,18" Padding="12,0"/>
                    <TextBlock Text="器械包搜索" Foreground="#123156" FontWeight="Bold" FontSize="16"/>
                    <TextBox x:Name="PackageCodeInput" Height="52" FontSize="20" Margin="0,8,0,14" Padding="12,0"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="器械包信息" Foreground="#176BFF" FontWeight="Bold" FontSize="20" Margin="0,0,0,12"/>
                            <TextBlock x:Name="PackageInfoText" Text="请扫描或选择器械包" FontSize="16" Foreground="#334155" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" Margin="22,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="190"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="当前回收单" Foreground="#176BFF" FontWeight="Bold" FontSize="22" Margin="0,0,0,16"/>
                                <TextBlock x:Name="CurrentOrderNoText" Text="回收单号  -" FontSize="18" Margin="0,0,0,12"/>
                                <TextBlock Text="来源方式  触摸台录入" FontSize="18" Margin="0,0,0,12"/>
                                <TextBlock x:Name="RecycleUserText" Text="回收人  -" FontSize="18"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#D8E4F4"/>
                            <StackPanel Grid.Column="2" Margin="40,0,0,0">
                                <TextBlock x:Name="TotalCountText" Text="包数量  0" FontSize="19" Margin="0,36,0,18"/>
                                <TextBlock x:Name="ReturnCountText" Text="还包数  0" FontSize="19"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="#176BFF" BorderThickness="2" CornerRadius="8" Background="White" Padding="20" Margin="0,22,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="扫描器械包条码 / 手动输入包码" Foreground="#176BFF" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,42,0,12"/>
                            <TextBlock DockPanel.Dock="Top" Text="请扫描条码或手动输入包码" Foreground="#65758B" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,36"/>
                            <ListView x:Name="PackageList" FontSize="16" SelectionChanged="PackageList_SelectionChanged">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="包条码" Width="150" DisplayMemberBinding="{Binding InstanceCode}"/>
                                        <GridViewColumn Header="包名称" Width="220" DisplayMemberBinding="{Binding PackageName}"/>
                                        <GridViewColumn Header="状态" Width="130" DisplayMemberBinding="{Binding StatusText}"/>
                                        <GridViewColumn Header="科室" Width="150" DisplayMemberBinding="{Binding DeptName}"/>
                                        <GridViewColumn Header="批次" Width="220" DisplayMemberBinding="{Binding BatchNo}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <UniformGrid Grid.Row="2" Columns="5" Margin="22,0,22,18">
                <Button x:Name="ScanButton" Content="扫码加入  F1" Style="{StaticResource TouchButton}" Background="#176BFF" Click="SubmitButton_Click"/>
                <Button Content="标记异常  F2" Style="{StaticResource TouchButton}" Background="#FF4A3D"/>
                <Button Content="保存草稿  F3" Style="{StaticResource TouchButton}" Background="#FF8A00"/>
                <Button x:Name="SubmitButton" Content="提交回收单  F4" Style="{StaticResource TouchButton}" Background="#08A887" Click="SubmitButton_Click"/>
                <Button Content="进入待清洗  F5" Style="{StaticResource TouchButton}" Background="#073D94"/>
            </UniformGrid>
        </Grid>
    </Grid>
</Window>
