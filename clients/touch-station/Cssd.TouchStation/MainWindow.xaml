<Window x:Class="Cssd.TouchStation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSSD触摸台" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6F4">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="8" Padding="18" BorderBrush="#D9E1DD" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="CSSD触摸操作台" FontSize="28" FontWeight="Bold"/>
                    <TextBlock x:Name="StationText" Text="工位加载中" Foreground="#69756E" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RefreshButton" Content="刷新任务" Width="120" Height="46" Margin="0,0,10,0" Click="RefreshButton_Click"/>
                    <Button x:Name="SubmitButton" Content="确认操作" Width="140" Height="46" Background="#16794A" Foreground="White" Click="SubmitButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="8" Padding="16" BorderBrush="#D9E1DD" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="待处理任务" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ListView x:Name="PackageList" FontSize="18">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="包条码" Width="150" DisplayMemberBinding="{Binding InstanceCode}"/>
                                <GridViewColumn Header="包名称" Width="220" DisplayMemberBinding="{Binding PackageName}"/>
                                <GridViewColumn Header="状态" Width="140" DisplayMemberBinding="{Binding StatusText}"/>
                                <GridViewColumn Header="科室" Width="160" DisplayMemberBinding="{Binding DeptName}"/>
                                <GridViewColumn Header="批次" Width="230" DisplayMemberBinding="{Binding BatchNo}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="16" Margin="16,0,0,0" BorderBrush="#D9E1DD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="扫码区" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="扫码枪回车后会自动触发输入" Foreground="#69756E" Margin="0,6,0,14"/>
                    <TextBlock Text="包条码"/>
                    <TextBox x:Name="PackageCodeInput" Height="50" FontSize="24" Margin="0,6,0,12"/>
                    <TextBlock Text="筐/设备/目标科室"/>
                    <TextBox x:Name="SecondInput" Height="50" FontSize="24" Margin="0,6,0,12"/>
                    <TextBlock Text="操作提示" FontWeight="SemiBold" Margin="0,12,0,6"/>
                    <TextBlock x:Name="MessageText" Text="等待操作" TextWrapping="Wrap" Foreground="#16794A" FontSize="16"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
